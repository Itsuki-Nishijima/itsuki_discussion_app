.container
  .header
    = link_to "Boards", root_path, class: "header-title"
  .content
    = link_to "← Board詳細へ戻る", board_path(@board), class: "back-link"

    %h2.page-title Edit Boards

    - if @board.errors.any?
      .error-message
        %ul
          - @board.errors.full_messages.each do |message|
            %li= message

    = form_with model: @board, local: true do |f|
      .field
        = f.label :title
        = f.text_field :title, class: 'text'
      .field
        = f.label :description
        = f.text_area :description, class: 'text'
      .actions
        = f.submit "Update", class: 'btn-primary'